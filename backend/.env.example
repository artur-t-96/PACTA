# PARAGRAF Backend — Environment Variables
# Copy to .env and fill in values

# Required: Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-...

# Required: Voyage AI for RAG embeddings
VOYAGE_API_KEY=pa-...

# Optional: API key protection (simple mode)
PARAGRAF_API_KEY=

# Optional: Enable RBAC auth (role-based access control)
# When true, users need API key or login to access endpoints
PARAGRAF_AUTH=false

# Optional: Traffit ATS integration
TRAFFIT_API_KEY=
TRAFFIT_BASE_URL=https://api.traffit.com/v1

# Optional: MS365 email (auto-reads from ~/.secrets/ms365_tokens.json)
MS365_SENDER_EMAIL=administracja@b2bnet.pl

# Persistent data layout
PARAGRAF_DATA_DIR=/var/data
DATABASE_URL=sqlite:////var/data/paragraf.db
CHROMADB_PATH=/var/data/chromadb
TEMPLATE_PATH=/var/data/templates/Umowa_B2B_draft_2026_od_02.03.2026.docx
OUTPUT_DIR=/var/data/output/contracts
BACKUP_DIR=/var/data/backups
